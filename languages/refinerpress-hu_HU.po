msgstr "Eltávolítja a nyelvválasztó legördülő menüt a bejelentkezési képernyőről."

# Settings page - Role Redirects
msgid "Role"
msgstr "Szerepkör"

msgid "Redirect After Login"
msgstr "Átirányítás login után"

msgid "Redirect After Logout"
msgstr "Átirányítás logout után"

msgid "Leave fields empty where no custom redirect is needed."
msgstr "Hagyd üresen azokat a mezőket, ahol nincs szükség egyedi átirányításra."

# Settings page - Comments
msgid "Completely disable comments"
msgstr "Hozzászólások teljes letiltása"

msgid "Keep product reviews (WooCommerce)"
msgstr "Termék értékelések (WooCommerce) megtartása"

