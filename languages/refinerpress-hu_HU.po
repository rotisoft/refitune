msgstr "Frissítési értesítők letiltása (core, plugin, téma)"

msgid "Custom address (if provided, redirects instead of disabling):"
msgstr "Egyedi cím (ha megadva, letiltás helyett ide küldi):"

msgid "Disable new user registration — admin notification"
msgstr "Új felhasználó regisztráció — admin értesítő letiltása"

msgid "Disable password reset — admin notification"
msgstr "Jelszó visszaállítás — admin értesítő letiltása"

msgid "Disable comment notifications"
msgstr "Komment értesítők letiltása"

msgid "Disable privacy (GDPR) notifications"
msgstr "Adatvédelmi (GDPR) értesítők letiltása"

msgid "Disable critical error email"
msgstr "Kritikus hiba email letiltása"

# Settings page - Role Select
msgid "(required)"
msgstr "(kötelező)"

# Settings page - Login Limit
msgid "Maximum Attempts"
msgstr "Maximum kísérletek száma"

msgid "How many failed login attempts allowed per IP address and username. Default: 5"
msgstr "Hány sikertelen bejelentkezési kísérletet engedélyez IP címenként és felhasználónevenként. Alapértelmezett: 5"

msgid "Lockout Duration (minutes)"
msgstr "Kitiltás időtartama (perc)"

msgid "How long the user should be locked out after reaching the limit (in minutes). Default: 15 minutes"
msgstr "Mennyi ideig legyen kitiltva a felhasználó a limit elérése után (percben). Alapértelmezett: 15 perc"

msgid "Whitelist IP Addresses"
msgstr "Whitelist IP címek"

