msgstr "Kapcsold be, ha SSL tanúsítvány hibákat tapasztalsz helyi/fejlesztői környezetben. NEM ajánlott éles környezetben."

# Settings page - Login Customizer
msgid "Logo Settings"
msgstr "Logo beállítások"

msgid "Logo Source"
msgstr "Logo forrás"

msgid "Use Site Icon (Settings → General → Site Icon)"
msgstr "Site Icon használata (Beállítások → Általános → Webhely ikon)"

msgid "Custom Image URL (relative)"
msgstr "Egyedi kép URL (relatív)"

msgid "Logo Size"
msgstr "Logo méret"

msgid "Width:"
msgstr "Szélesség:"

msgid "Height:"
msgstr "Magasság:"

msgid "Color Settings"
msgstr "Színbeállítások"

msgid "Background Color"
msgstr "Háttérszín"

msgid "Login page background color. Default: #f0f0f1"
msgstr "A login oldal háttérszíne. Alapértelmezett: #f0f0f1"

msgid "Primary Color"
msgstr "Primary szín"

msgid "Login button color. Default: #3858e9"
msgstr "A \"Bejelentkezés\" gomb színe. Alapértelmezett: #3858e9"

msgid "Language Switcher"
msgstr "Nyelvválasztó"

msgid "Hide language switcher on login page"
msgstr "Nyelvválasztó elrejtése a bejelentkezési oldalon"

